fn main() {
    var line char[32] = "SCORE "
    var score int = 12345
    var neg int = -123

    cls()

    append(line, itoa(score))
    putstr(0, 0, line)

    clear(line)
    copy(line, "NEG ")
    append(line, itoa(neg))
    putstr(0, 2, line)

    clear(line)
    copy(line, "MIN ")
    append(line, itoa(-32768))
    putstr(0, 4, line)

    clear(line)
    copy(line, "ZERO ")
    append(line, itoa(0))
    putstr(0, 6, line)

    gotoxy(0, 22)
}

fn draw(x byte, y byte) {
    putchar(x, y, '@')
}

fn erase(x byte, y byte) {
    putchar(x, y, ' ')
}

fn printjoy(j byte) {
    var line char[16] = "JOY "

    append(line, itoa(j))

    putstr(0, 4, "        ")
    putstr(0, 4, line)
}

fn printticks(t int) {
    var line char[20] = "ELAPSED "

    append(line, itoa(t))

    putstr(0, 5, "              ")
    putstr(0, 5, line)
}

fn main() {
    var x byte = 20
    var y byte = 12
    var j byte = 31
    var done bool = false
    var moved bool
    var lastMove int
    var moveEvery int = 4

    cls()
    textcolor(1)
    lastMove = ticks()

    putstr(0, 0, "JOYSTICK PORT 2")
    putstr(0, 1, "MOVE WITH JOYSTICK")
    putstr(0, 2, "FIRE TO QUIT")
    putstr(0, 3, "IDLE SHOULD BE 31")

    printjoy(j)
    printticks(0)
    draw(x, y)

    while done == false {
        printticks(elapsed(lastMove))

        if tickdue(lastMove, moveEvery) {
            lastMove = ticks()

            j = joy(2) & 31
            printjoy(j)

            moved = false

            if (j & 16) == 0 {
                done = true
            }

            if done == false {
                if (j & 4) == 0 {
                    if x > 0 {
                        erase(x, y)
                        x = x - 1
                        moved = true
                    }
                }

                if moved == false {
                    if (j & 8) == 0 {
                        if x < 39 {
                            erase(x, y)
                            x = x + 1
                            moved = true
                        }
                    }
                }

                if moved == false {
                    if (j & 1) == 0 {
                        if y > 6 {
                            erase(x, y)
                            y = y - 1
                            moved = true
                        }
                    }
                }

                if moved == false {
                    if (j & 2) == 0 {
                        if y < 24 {
                            erase(x, y)
                            y = y + 1
                            moved = true
                        }
                    }
                }

                if moved == true {
                    draw(x, y)
                }
            }
        }
    }

    gotoxy(0, 22)
}

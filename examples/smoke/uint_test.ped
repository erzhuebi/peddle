# uint self-test.
#
# This checks the cases most likely to break if uint is accidentally treated
# as signed int: values with bit 15 set, unsigned comparisons against small
# values, 16-bit wraparound, masks, and storing addresses.

fn main() {
    var ok bool = true

    var hi uint = 65535
    var mid uint = 32768
    var low uint = 1
    var border uint = 0xd020
    var wrap uint = hi + low
    var mask uint = hi & 0xff00

    var x byte = 7
    var addr uint = &x

    var data byte[4] = [11, 22]
    var data0 uint = &data[0]
    var data1 uint = &data[1]

    var words uint[2] = [65535, 32768]
    var word0 uint = &words[0]
    var word1 uint = &words[1]

    if hi != 65535 {
        print("FAIL UINT MAX LOAD\n")
        ok = false
    }

    if mid != 32768 {
        print("FAIL UINT HIGH LOAD\n")
        ok = false
    }

    if hi <= low {
        print("FAIL 65535 <= 1\n")
        ok = false
    }

    if low >= hi {
        print("FAIL 1 >= 65535\n")
        ok = false
    }

    if mid <= low {
        print("FAIL 32768 <= 1\n")
        ok = false
    }

    if low >= mid {
        print("FAIL 1 >= 32768\n")
        ok = false
    }

    if border <= low {
        print("FAIL $D020 <= 1\n")
        ok = false
    }

    if wrap != 0 {
        print("FAIL UINT WRAP\n")
        ok = false
    }

    if mask != 0xff00 {
        print("FAIL UINT MASK HIGH\n")
        ok = false
    }

    mask = hi & 0x000f
    if mask != 0x000f {
        print("FAIL UINT MASK LOW\n")
        ok = false
    }

    if addr == 0 {
        print("FAIL SCALAR ADDRESS\n")
        ok = false
    }

    if data1 != data0 + 1 {
        print("FAIL BYTE ARRAY ADDRESS\n")
        ok = false
    }

    if words[0] <= words[1] {
        print("FAIL UINT ARRAY COMPARE\n")
        ok = false
    }

    if word1 != word0 + 2 {
        print("FAIL UINT ARRAY ADDRESS\n")
        ok = false
    }

    if ok {
        print("TEST SUCCESSFUL")
    } else {
        print("TEST FAILED")
    }
}

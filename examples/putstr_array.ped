fn main() {
    var title char[32]
    var line char[32]

    cls()

    border(6)
    background(0)
    textcolor(1)

    copy(title, "DYNAMIC ")
    append(title, "PUTSTR")

    copy(line, "COLOR ")
    append(line, "ARRAY")

    putstr(0, 0, "LITERAL OK")
    putstr(0, 2, title)

    putstrcolor(0, 4, "COLOR LITERAL", 2)
    putstrcolor(0, 6, line, 5)

    gotoxy(0, 24)
}